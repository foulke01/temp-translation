<script>
  const tt = document.getElementById('tt');
  document.querySelectorAll('.prow[data-tip]').forEach(el => {
    el.addEventListener('mouseenter', () => { tt.innerHTML = el.dataset.tip; tt.style.display = 'block'; });
    el.addEventListener('mousemove', e => {
      let x = e.clientX + 14, y = e.clientY + 14;
      if (x + 270 > window.innerWidth)  x = e.clientX - 280;
      if (y + 180 > window.innerHeight) y = e.clientY - 180;
      tt.style.left = x + 'px';
      tt.style.top  = y + 'px';
    });
    el.addEventListener('mouseleave', () => { tt.style.display = 'none'; });
  });
</script>
